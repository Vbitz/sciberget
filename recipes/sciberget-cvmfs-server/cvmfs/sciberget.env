SCIBERGET_CVMFS_REPO="${SCIBERGET_CVMFS_REPO:-sciberget.example.org}"
SCIBERGET_CVMFS_ROOT="${SCIBERGET_CVMFS_ROOT:-/cvmfs/${SCIBERGET_CVMFS_REPO}}"
SCIBERGET_CONTAINERS_DIR="${SCIBERGET_CONTAINERS_DIR:-containers}"
SCIBERGET_MODULES_DIR="${SCIBERGET_MODULES_DIR:-sciberget-modules}"
SCIBERGET_OBJECT_BASE_URL="${SCIBERGET_OBJECT_BASE_URL:-https://example.org/sciberget}"
SCIBERGET_COMMAND_REPO_PATH="${SCIBERGET_COMMAND_REPO_PATH:-$(pwd -P)}"
SCIBERGET_TRANSPARENT_SINGULARITY_REPO="${SCIBERGET_TRANSPARENT_SINGULARITY_REPO:-https://github.com/NeuroDesk/transparent-singularity}"
SCIBERGET_DRY_RUN="${SCIBERGET_DRY_RUN:-false}"
SCIBERGET_DISABLE_STALE="${SCIBERGET_DISABLE_STALE:-false}"
SCIBERGET_TAG_RETENTION="${SCIBERGET_TAG_RETENTION:-20}"
